# =============================================================================
#  BTC Vault Autonomous Agents — Environment Configuration
#  Copy this file to .env and fill in your values before running.
# =============================================================================

# ── Starknet Network ─────────────────────────────────────────────────────────
# Options: mainnet | sepolia
STARKNET_NETWORK=sepolia

# Starknet RPC endpoint. Free public endpoints:
#   Sepolia : https://free-rpc.nethermind.io/sepolia-juno/
#   Mainnet : https://free-rpc.nethermind.io/mainnet-juno/
STARKNET_RPC_URL=https://free-rpc.nethermind.io/sepolia-juno/

# ── Contract Addresses ───────────────────────────────────────────────────────
# Fill these after running `sncast deploy` (see vault/deployments.txt)
ROUTER_ADDRESS=0x0
VAULT_ADDRESS=0x0

# ── Risk Sentinel Wallet ─────────────────────────────────────────────────────
# This account must hold ROLE_GUARDIAN on the Router (enter_safe_mode)
# and ROLE_KEEPER on the Router (refresh_btc_price).
RISK_SENTINEL_PRIVATE_KEY=0x0
RISK_SENTINEL_ADDRESS=0x0

# ── Strategy Rebalancer Wallet ───────────────────────────────────────────────
# This account must hold ROLE_KEEPER on the Vault (trigger_yield_accrual)
# and ROLE_KEEPER on the Router (refresh_btc_price).
REBALANCER_PRIVATE_KEY=0x0
REBALANCER_ADDRESS=0x0

# ── User Guardian Wallet ─────────────────────────────────────────────────────
# This account must hold ROLE_LIQUIDATOR on the Vault (liquidate).
GUARDIAN_PRIVATE_KEY=0x0
GUARDIAN_ADDRESS=0x0

# ── Agent Poll Intervals (seconds) ───────────────────────────────────────────
RISK_SENTINEL_INTERVAL=60        # 1 min — critical safety loop
REBALANCER_INTERVAL=300          # 5 min — yield & leverage health
GUARDIAN_INTERVAL=30             # 30 sec — liquidation watch

# ── Risk Thresholds ──────────────────────────────────────────────────────────
# Trigger safe mode when BTC drops more than this % in the last hour
MAX_PRICE_DROP_PCT=10.0
# Trigger safe mode when annualised 24-h volatility exceeds this
MAX_VOLATILITY_24H=0.80
# Only rebalance if leverage delta exceeds this fraction (0.1 = 10%)
LEVERAGE_REBALANCE_THRESHOLD=0.1
# Warn users when their health factor falls below this (×100, e.g. 130 = 1.30)
GUARDIAN_WARN_HEALTH=130
# Liquidate positions whose health factor is at or below this (100 = 1.00)
GUARDIAN_LIQUIDATE_HEALTH=100

# ── Price Feed ───────────────────────────────────────────────────────────────
# Number of price samples to keep (used for rolling volatility).
# 288 = 24 h at 5-min sample rate, aligned with REBALANCER_INTERVAL.
PRICE_HISTORY_SIZE=288
# Maximum age of a single price sample before it is discarded (seconds)
PRICE_SAMPLE_MAX_AGE=600

# ── Mock Oracle Keeper (Sepolia testnet only) ─────────────────────────────────
# When running against the MockPragmaOracle deployed on Sepolia, the sentinel
# needs to push a fresh price to the oracle before each refresh_btc_price call
# (the router enforces MAX_PRICE_AGE = 3600 s on oracle data).
#
# Set these to the oracle contract address and the *deployer* account that owns
# the MockPragmaOracle.  Leave blank to skip (use a real Pragma oracle instead).
ORACLE_ADDRESS=0x0                   # MockPragmaOracle address (Sepolia)
ORACLE_OWNER_PRIVATE_KEY=0x0         # Deployer private key (oracle owner)
ORACLE_OWNER_ADDRESS=0x0             # Deployer address

# ── Logging ───────────────────────────────────────────────────────────────────
# Options: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# Options: json | console
LOG_FORMAT=json

# ── Prometheus Metrics ────────────────────────────────────────────────────────
ENABLE_METRICS=false
METRICS_PORT=9090
